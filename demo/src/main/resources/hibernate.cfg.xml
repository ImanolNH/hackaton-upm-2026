<hibernate-configuration>
    <session-factory>

        <!-- Conexión -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url"> jdbc:mysql://127.0.0.1:3306/registroClimatico?useSSL=false</property>
        <property name="hibernate.connection.username">appuser</property>
        <property name="hibernate.connection.password">1234</property>

        <!-- Dialecto -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQL8Dialect</property>

        <!-- Crear tablas automáticamente -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Mostrar SQL en consola -->
        <property name="hibernate.show_sql">true</property>

        <!-- Registrar entidades -->
            <mapping class="hackatonScrumless.Usuario"/>

    </session-factory>
</hibernate-configuration>
